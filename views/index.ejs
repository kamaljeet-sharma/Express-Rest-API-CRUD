<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>all post</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <div class="navbar">
        <h2>ज़िंदगी पर ख़ूबसूरत शेर</h2>
        <a href="/posts">Home</a>
        <a href="/posts/new">Create</a>
    </div>

    <h1>Post Your Emotions In Sayari</h1>
    <% for (post of posts) { %>
        <div class="post">
            <h3 class="user">@ <%=post.username %>
            </h3>
            <h4 class="content">
                <%=post.content %>
            </h4>
            <br>
            <div class="actions">
                <a href="/posts/<%= post.id %>" class="view">See Details</a>
                <a href="/posts/<%= post.id %>/edit" class="edit">Edit</a>
            </div>
            <form action="/posts/<%=post.id%>?_method=DELETE" method="POST">
                <button type="submit">Delete</button>
            </form>
        </div>
        <% } %>
            <br> <br>
            <button><a href="/posts/new">Create New Post</a></button>
</body>

</html>